<!DOCTYPE html>
<html>
<head>
<title>Card Layout</title>
<style>
body{
font-family: Arial;
text-align: center;
}
.container{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
padding:20px;
}
.card{
width:250px;
border:2px solid black;
background-color:white;
padding:15px;
}
.card img{
width:100%;
height:150px;
}
button{
padding:10px 20px;
background-color:blue;
color:white;
border:none;
cursor:pointer;
}
button:hover{
color:rgb(240, 240, 240);
}
</style>
</head>
<body>
<h1>Card Layout</h1>
<div class="container">
<div class="card">
<img src="moon1.jpg">
<p>Full Moon Energy</p>
<button>Click Here</button>
</div>
<div class="card">
<img src="moon1.jpg">
<p>Even in darkness, the moon still shines</p>
<button>Click Here</button>
</div>
<div class="card">
<img src="moon1.jpg">
<p>The moon paints the night with silver light</p>
<button>Click Here</button>
</div>
</div>
</body>
</html>
